module transmitter #(
    parameter integer CLOCKS_PER_PULSE = 16
)(
    input  wire [7:0] data_in,
    input  wire       data_en,
    input  wire       clk,
    input  wire       rstn,
    output reg        tx,
    output wire       tx_busy
);
    // State encoding (replaces typedef enum)
    localparam [1:0] TX_IDLE  = 2'd0,
                     TX_START = 2'd1,
                     TX_DATA  = 2'd2,
                     TX_STOP  = 2'd3;

    reg [1:0] state;
    reg [7:0] data_reg;
    reg [2:0] bit_count;
    reg [$clog2(CLOCKS_PER_PULSE)-1:0] clk_count;
    reg data_en_d;

    wire start_pulse;
    assign start_pulse = data_en & ~data_en_d;
    assign tx_busy     = (state != TX_IDLE);

    always @(posedge clk or negedge rstn) begin
        if (!rstn) begin
            data_en_d <= 1'b0;
            state     <= TX_IDLE;
            data_reg  <= 8'd0;
            bit_count <= 3'd0;
            clk_count <= {$clog2(CLOCKS_PER_PULSE){1'b0}};
            tx        <= 1'b1;
        end else begin
            data_en_d <= data_en;
            case (state)
                TX_IDLE: begin
                    tx        <= 1'b1;
                    clk_count <= {$clog2(CLOCKS_PER_PULSE){1'b0}};
                    bit_count <= 3'd0;
                    if (start_pulse) begin
                        data_reg <= data_in;
                        state    <= TX_START;
                    end
                end
                TX_START: begin
                    tx <= 1'b0;
                    if (clk_count == CLOCKS_PER_PULSE-1) begin
                        clk_count <= {$clog2(CLOCKS_PER_PULSE){1'b0}};
                        state     <= TX_DATA;
                    end else begin
                        clk_count <= clk_count + 1'b1;
                    end
                end
                TX_DATA: begin
                    tx <= data_reg[bit_count];
                    if (clk_count == CLOCKS_PER_PULSE-1) begin
                        clk_count <= {$clog2(CLOCKS_PER_PULSE){1'b0}};
                        if (bit_count == 3'd7) begin
                            bit_count <= 3'd0;
                            state     <= TX_STOP;
                        end else begin
                            bit_count <= bit_count + 1'b1;
                        end
                    end else begin
                        clk_count <= clk_count + 1'b1;
                    end
                end
                TX_STOP: begin
                    tx <= 1'b1;
                    if (clk_count == CLOCKS_PER_PULSE-1) begin
                        clk_count <= {$clog2(CLOCKS_PER_PULSE){1'b0}};
                        state     <= TX_IDLE;
                    end else begin
                        clk_count <= clk_count + 1'b1;
                    end
                end
                default: begin
                    state <= TX_IDLE;
                    tx    <= 1'b1;
                end
            endcase
        end
    end
endmodule