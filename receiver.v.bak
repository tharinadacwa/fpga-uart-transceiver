module receiver #(
    parameter integer CLOCKS_PER_PULSE = 16
)(
    input  wire       clk,
    input  wire       rstn,
    input  wire       ready_clr,
    input  wire       rx,
    output reg        ready,
    output wire [7:0] data_out
);
    // State encoding (replaces typedef enum)
    localparam [1:0] RX_IDLE  = 2'd0,
                     RX_START = 2'd1,
                     RX_DATA  = 2'd2,
                     RX_STOP  = 2'd3;

    reg [1:0] state;
    reg [2:0] bit_count;
    reg [$clog2(CLOCKS_PER_PULSE)-1:0] clk_count;
    reg [7:0] data_reg;
    reg rx_sync_1, rx_sync_2;

    assign data_out = data_reg;

    // Two-flop synchronizer for rx input
    always @(posedge clk or negedge rstn) begin
        if (!rstn) begin
            rx_sync_1 <= 1'b1;
            rx_sync_2 <= 1'b1;
        end else begin
            rx_sync_1 <= rx;
            rx_sync_2 <= rx_sync_1;
        end
    end

    // Main FSM
    always @(posedge clk or negedge rstn) begin
        if (!rstn) begin
            state     <= RX_IDLE;
            clk_count <= {$clog2(CLOCKS_PER_PULSE){1'b0}};
            bit_count <= 3'd0;
            data_reg  <= 8'd0;
            ready     <= 1'b0;
        end else begin
            if (ready_clr)
                ready <= 1'b0;
            case (state)
                RX_IDLE: begin
                    clk_count <= {$clog2(CLOCKS_PER_PULSE){1'b0}};
                    bit_count <= 3'd0;
                    if (rx_sync_2 == 1'b0)
                        state <= RX_START;
                end
                RX_START: begin
                    if (clk_count == (CLOCKS_PER_PULSE/2)-1) begin
                        clk_count <= {$clog2(CLOCKS_PER_PULSE){1'b0}};
                        if (rx_sync_2 == 1'b0)
                            state <= RX_DATA;
                        else
                            state <= RX_IDLE;
                    end else begin
                        clk_count <= clk_count + 1'b1;
                    end
                end
                RX_DATA: begin
                    if (clk_count == CLOCKS_PER_PULSE-1) begin
                        clk_count           <= {$clog2(CLOCKS_PER_PULSE){1'b0}};
                        data_reg[bit_count] <= rx_sync_2;
                        if (bit_count == 3'd7) begin
                            bit_count <= 3'd0;
                            state     <= RX_STOP;
                        end else begin
                            bit_count <= bit_count + 1'b1;
                        end
                    end else begin
                        clk_count <= clk_count + 1'b1;
                    end
                end
                RX_STOP: begin
                    if (clk_count == CLOCKS_PER_PULSE-1) begin
                        clk_count <= {$clog2(CLOCKS_PER_PULSE){1'b0}};
                        if (rx_sync_2 == 1'b1)
                            ready <= 1'b1;
                        state <= RX_IDLE;
                    end else begin
                        clk_count <= clk_count + 1'b1;
                    end
                end
                default: state <= RX_IDLE;
            endcase
        end
    end
endmodule